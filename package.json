{
  "name": "jobshield-ai",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered job scam detection platform monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "echo Define frontend and backend dev scripts after app setup",
    "build": "echo Define build scripts after app setup",
    "smoke:test": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1",
    "smoke:test:quick": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1 -Indices \"0,7,22,55,70\"",
    "smoke:test:full": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1 -AllDataset",
    "smoke:test:sweep": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1 -AllDataset -SweepThresholds -NoFailOnMismatch"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
